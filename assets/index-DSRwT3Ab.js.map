[
  { "id": "accurate_attack", "name": "Accurate Attack", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Trade effect DC for attack bonus.", "longDescription": "When you make a close or ranged attack you can take a penalty of up to -5 on the effect bonus and add the same number (up to +5) to your attack bonus.", "i18n": { "pt-BR": { "name": "Ataque Preciso", "description": "Trocar DC do efeito por bônus de ataque.", "longDescription": "Ao fazer um ataque corpo a corpo ou à distância, você pode receber uma penalidade de até -5 no bônus do efeito e adicionar o mesmo número (até +5) ao seu bônus de ataque." } } },
  { "id": "all_out_attack", "name": "All-out Attack", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Trade defense bonus for attack bonus up to +5.", "longDescription": "When you make an attack you can take a penalty of up to -5 on your active defenses (Dodge and Parry) and add the same number (up to +5) to your attack bonus.", "i18n": { "pt-BR": { "name": "Ataque Total", "description": "Trocar bônus de defesa por bônus de ataque até +5.", "longDescription": "Ao fazer um ataque, você pode receber uma penalidade de até -5 nas suas defesas ativas (Esquiva e Aparar) e adicionar o mesmo número (até +5) ao seu bônus de ataque." } } },
  { "id": "chokehold", "name": "Chokehold", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Suffocate a grabbed opponent.", "longDescription": "If you successfully grab and restrain an opponent you can apply a suffocation hazard to them. The target must make a Fortitude resistance check (DC 10 plus your Strength) each round to avoid suffocation.", "i18n": { "pt-BR": { "name": "Estrangulamento", "description": "Sufocar um oponente agarrado.", "longDescription": "Se você agarrar e imobilizar um oponente com sucesso, pode aplicar um perigo de sufocação. O alvo deve fazer um teste de resistência de Fortitude (CD 10 mais sua Força) a cada rodada para evitar sufocação." } } },
  { "id": "close_attack", "name": "Close Attack", "advantageType": "combat", "ranked": true, "maxRank": null, "description": "+1 to close attack bonus per rank.", "longDescription": "You have a +1 bonus to close attacks checks per rank of this advantage. Your total attack bonus is still limited by power level.", "i18n": { "pt-BR": { "name": "Ataque Corpo-a-Corpo", "description": "+1 ao bônus de ataque corpo-a-corpo por rank.", "longDescription": "Você recebe +1 de bônus em testes de ataque corpo a corpo por rank desta vantagem. Seu bônus de ataque total ainda é limitado pelo nível de poder." } } },
  { "id": "defensive_attack", "name": "Defensive Attack", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Trade attack bonus for defense bonus.", "longDescription": "When you make an attack you can take a penalty of up to -5 on your attack bonus and add the same number (up to +5) to both your active defenses (Dodge and Parry) until the start of your next turn.", "i18n": { "pt-BR": { "name": "Ataque Defensivo", "description": "Trocar bônus de ataque por bônus de defesa.", "longDescription": "Ao fazer um ataque, você pode receber uma penalidade de até -5 no bônus de ataque e adicionar o mesmo número (até +5) às suas defesas ativas (Esquiva e Aparar) até o início do seu próximo turno." } } },
  { "id": "defensive_roll", "name": "Defensive Roll", "advantageType": "combat", "ranked": true, "maxRank": null, "description": "+1 Toughness per rank (active only).", "longDescription": "You can avoid damage through agility and rolling with an attack. You receive a bonus to your Toughness equal to your advantage rank, but it is considered an active defense similar to Dodge and Parry, so you lose this bonus when you are vulnerable or defenseless.", "i18n": { "pt-BR": { "name": "Rolamento Defensivo", "description": "+1 de Resistência por rank (apenas ativo).", "longDescription": "Você evita dano através da agilidade e rolando com um ataque. Recebe um bônus à sua Resistência igual ao rank da vantagem, mas é considerada uma defesa ativa similar a Esquiva e Aparar, então você perde este bônus quando está vulnerável ou indefeso." } } },
  { "id": "evasion", "name": "Evasion", "advantageType": "combat", "ranked": true, "maxRank": 2, "description": "Bonus to Dodge vs. area effects.", "longDescription": "You have a +2 circumstance bonus to Dodge resistance checks to avoid area effects. If you succeed, you take no effect (rather than half). With 2 ranks, your bonus is +5 and you still suffer no effect on a successful resistance check.", "i18n": { "pt-BR": { "name": "Evasão", "description": "Bônus em Esquiva vs. efeitos de área.", "longDescription": "Você recebe +2 de bônus circunstancial em testes de resistência de Esquiva para evitar efeitos de área. Se obtiver sucesso, não sofre nenhum efeito (ao invés de metade). Com 2 ranks, seu bônus é +5 e você não sofre efeito em um teste bem-sucedido." } } },
  { "id": "fast_grab", "name": "Fast Grab", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Make a free grab after a close attack hit.", "longDescription": "When you hit with an unarmed close attack you can immediately make a grab check against that opponent as a free action. Your attack still does its normal damage.", "i18n": { "pt-BR": { "name": "Agarrão Rápido", "description": "Fazer um agarrão livre após acertar ataque corpo a corpo.", "longDescription": "Quando você acerta um ataque corpo a corpo desarmado, pode imediatamente fazer um teste de agarrar contra o oponente como ação livre. Seu ataque ainda causa seu dano normal." } } },
  { "id": "favored_environment", "name": "Favored Environment", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "+2 circumstance bonus in a chosen environment.", "longDescription": "You have a particular environment in which your abilities are at their peak. Choose an environment type (aerial, aquatic, urban, etc.). While in that environment you gain a +2 circumstance bonus on attack checks and your active defenses.", "i18n": { "pt-BR": { "name": "Ambiente Favorito", "description": "+2 de bônus circunstancial em um ambiente escolhido.", "longDescription": "Você tem um ambiente específico onde suas habilidades estão em seu auge. Escolha um tipo de ambiente (aéreo, aquático, urbano, etc.). Enquanto nesse ambiente, você ganha +2 de bônus circunstancial em testes de ataque e suas defesas ativas." } } },
  { "id": "grabbing_finesse", "name": "Grabbing Finesse", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Use Dex-based skill for grab attacks.", "longDescription": "You can use your Dexterity bonus, rather than Strength, for grab attack checks and grab escape DCs. You are not considered vulnerable while grabbing.", "i18n": { "pt-BR": { "name": "Finesse de Agarrar", "description": "Usar perícia baseada em Destreza para ataques de agarrar.", "longDescription": "Você pode usar seu bônus de Destreza, ao invés de Força, para testes de ataque de agarrar e CDs de escape de agarrar. Você não é considerado vulnerável enquanto agarra." } } },
  { "id": "improved_aim", "name": "Improved Aim", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Double bonus from aiming.", "longDescription": "You have an even keener eye when it comes to ranged combat. When you take the aim action you get double the normal circumstance bonus: +10 for a specific target or +4 for targeting in general.", "i18n": { "pt-BR": { "name": "Mira Aprimorada", "description": "Dobrar bônus ao mirar.", "longDescription": "Você tem um olho ainda mais aguçado para combate à distância. Quando realiza a ação de mirar, recebe o dobro do bônus circunstancial normal: +10 para um alvo específico ou +4 para mira geral." } } },
  { "id": "improved_critical", "name": "Improved Critical", "advantageType": "combat", "ranked": true, "maxRank": 4, "description": "Increase critical threat range by +1 per rank.", "longDescription": "Increase your critical threat range with a particular attack (chosen when you acquire this advantage) by +1, to a maximum of 16-20 with 4 ranks. Each different attack requires a separate Improved Critical advantage.", "i18n": { "pt-BR": { "name": "Crítico Aprimorado", "description": "Aumentar faixa de ameaça de crítico em +1 por rank.", "longDescription": "Aumente sua faixa de ameaça de acerto crítico com um ataque específico (escolhido ao adquirir esta vantagem) em +1, até um máximo de 16-20 com 4 ranks. Cada ataque diferente requer uma vantagem Crítico Aprimorado separada." } } },
  { "id": "improved_defense", "name": "Improved Defense", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "+2 bonus when using defend action.", "longDescription": "When you take the defend action in combat you gain a +2 circumstance bonus to your active defense checks for the round.", "i18n": { "pt-BR": { "name": "Defesa Aprimorada", "description": "+2 de bônus ao usar ação de defender.", "longDescription": "Quando você realiza a ação de defender em combate, recebe +2 de bônus circunstancial nos seus testes de defesa ativa pela rodada." } } },
  { "id": "improved_disarm", "name": "Improved Disarm", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "No penalty for disarm; +2 if opponent fails.", "longDescription": "You have no penalty to your attack check when attempting to disarm an opponent and they do not get the opportunity to disarm you. When your disarm attempt succeeds, you can choose to take the item if you have a free hand.", "i18n": { "pt-BR": { "name": "Desarme Aprimorado", "description": "Sem penalidade para desarmar; +2 se oponente falhar.", "longDescription": "Você não sofre penalidade no teste de ataque ao tentar desarmar um oponente e ele não tem oportunidade de desarmá-lo. Quando sua tentativa de desarme tem sucesso, você pode escolher pegar o item se tiver uma mão livre." } } },
  { "id": "improved_grab", "name": "Improved Grab", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Grab with one arm; not vulnerable while grabbing.", "longDescription": "You can make grab attacks with only one arm, leaving the other free. You are not vulnerable while grabbing an opponent.", "i18n": { "pt-BR": { "name": "Agarrão Aprimorado", "description": "Agarrar com um braço; não vulnerável ao agarrar.", "longDescription": "Você pode fazer ataques de agarrar com apenas um braço, deixando o outro livre. Você não é considerado vulnerável enquanto agarra um oponente." } } },
  { "id": "improved_hold", "name": "Improved Hold", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Better resistance DC for held opponents.", "longDescription": "When you successfully restrain an opponent, the DC of the check for the opponent to escape is increased by +2.", "i18n": { "pt-BR": { "name": "Imobilização Aprimorada", "description": "Melhor CD de resistência para oponentes imobilizados.", "longDescription": "Quando você imobiliza um oponente com sucesso, a CD do teste do oponente para escapar é aumentada em +2." } } },
  { "id": "improved_initiative", "name": "Improved Initiative", "advantageType": "combat", "ranked": true, "maxRank": null, "description": "+4 to Initiative bonus per rank.", "longDescription": "You have a +4 bonus to your initiative checks per rank of this advantage.", "i18n": { "pt-BR": { "name": "Iniciativa Aprimorada", "description": "+4 de bônus de Iniciativa por rank.", "longDescription": "Você recebe +4 de bônus nos seus testes de iniciativa por rank desta vantagem." } } },
  { "id": "improved_smash", "name": "Improved Smash", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "No penalty for smash attack.", "longDescription": "You have no penalty to attack checks to hit an object held by another character.", "i18n": { "pt-BR": { "name": "Esmagar Aprimorado", "description": "Sem penalidade para ataque de esmagar.", "longDescription": "Você não sofre penalidade em testes de ataque para acertar um objeto segurado por outro personagem." } } },
  { "id": "improved_trip", "name": "Improved Trip", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "No penalty for trip; +2 vs. opponent.", "longDescription": "You have no penalty to your attack check to trip an opponent and they do not get the opportunity to trip you. If your trip attempt succeeds, the target is prone.", "i18n": { "pt-BR": { "name": "Rasteira Aprimorada", "description": "Sem penalidade para rasteira; +2 vs. oponente.", "longDescription": "Você não sofre penalidade no teste de ataque para derrubar um oponente e ele não tem oportunidade de derrubá-lo. Se sua tentativa de rasteira obtiver sucesso, o alvo fica caído." } } },
  { "id": "improvised_weapon", "name": "Improvised Weapon", "advantageType": "combat", "ranked": true, "maxRank": null, "description": "Use improvised weapons without penalty.", "longDescription": "You can use improvised close combat weapons — chairs, bottles, trash cans, etc. — without penalty. Each rank adds +1 to their damage bonus, to a maximum equal to your Strength damage bonus.", "i18n": { "pt-BR": { "name": "Arma Improvisada", "description": "Usar armas improvisadas sem penalidade.", "longDescription": "Você pode usar armas improvisadas de combate corpo a corpo — cadeiras, garrafas, latas de lixo, etc. — sem penalidade. Cada rank adiciona +1 ao bônus de dano, até um máximo igual ao seu bônus de dano de Força." } } },
  { "id": "move_by_action", "name": "Move-by Action", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Move before and after a standard action.", "longDescription": "When taking a standard action and a move action you can move both before and after your standard action, provided the total distance moved isn't greater than your normal movement speed.", "i18n": { "pt-BR": { "name": "Ação em Movimento", "description": "Mover antes e depois de uma ação padrão.", "longDescription": "Ao realizar uma ação padrão e uma ação de movimento, você pode se mover antes e depois da ação padrão, desde que a distância total não exceda sua velocidade de movimento normal." } } },
  { "id": "power_attack", "name": "Power Attack", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Trade attack bonus for effect DC up to +5.", "longDescription": "When you make a close or ranged attack you can take a penalty of up to -5 on your attack bonus and add the same number (up to +5) to the effect bonus of your attack.", "i18n": { "pt-BR": { "name": "Ataque Poderoso", "description": "Trocar bônus de ataque por DC do efeito até +5.", "longDescription": "Ao fazer um ataque corpo a corpo ou à distância, você pode receber uma penalidade de até -5 no bônus de ataque e adicionar o mesmo número (até +5) ao bônus do efeito do ataque." } } },
  { "id": "precise_attack", "name": "Precise Attack", "advantageType": "combat", "ranked": true, "maxRank": 4, "description": "Ignore cover/concealment penalty.", "longDescription": "You can ignore the penalty for cover or concealment on your attacks (choose one: close/cover, close/concealment, ranged/cover, or ranged/concealment). Each rank applies to a different combination.", "i18n": { "pt-BR": { "name": "Ataque Certeiro", "description": "Ignorar penalidade de cobertura/ocultação.", "longDescription": "Você pode ignorar a penalidade por cobertura ou ocultação nos seus ataques (escolha uma: corpo a corpo/cobertura, corpo a corpo/ocultação, distância/cobertura, ou distância/ocultação). Cada rank aplica-se a uma combinação diferente." } } },
  { "id": "prone_fighting", "name": "Prone Fighting", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "No penalties for fighting prone.", "longDescription": "You suffer no circumstance penalty to attack checks for being prone and opponents do not gain the usual circumstance bonus for close attacks against you while you are prone.", "i18n": { "pt-BR": { "name": "Luta no Chão", "description": "Sem penalidades por lutar caído.", "longDescription": "Você não sofre penalidade circunstancial em testes de ataque por estar caído e oponentes não ganham o bônus circunstancial usual para ataques corpo a corpo contra você enquanto está caído." } } },
  { "id": "quick_draw", "name": "Quick Draw", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Draw a weapon as a free action.", "longDescription": "You can draw a weapon from a holster or sheath as a free action, rather than requiring a move action to do so.", "i18n": { "pt-BR": { "name": "Saque Rápido", "description": "Sacar uma arma como ação livre.", "longDescription": "Você pode sacar uma arma de um coldre ou bainha como ação livre, ao invés de precisar de uma ação de movimento." } } },
  { "id": "ranged_attack", "name": "Ranged Attack", "advantageType": "combat", "ranked": true, "maxRank": null, "description": "+1 to ranged attack bonus per rank.", "longDescription": "You have a +1 bonus to ranged attacks checks per rank of this advantage. Your total attack bonus is still limited by power level.", "i18n": { "pt-BR": { "name": "Ataque à Distância", "description": "+1 ao bônus de ataque à distância por rank.", "longDescription": "Você recebe +1 de bônus em testes de ataque à distância por rank desta vantagem. Seu bônus de ataque total ainda é limitado pelo nível de poder." } } },
  { "id": "redirect", "name": "Redirect", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Redirect a missed attack to another target.", "longDescription": "If you successfully use the Deception skill to trick an opponent in combat, you can redirect a missed melee attack against you to hit another target within range as a reaction.", "i18n": { "pt-BR": { "name": "Redirecionar", "description": "Redirecionar um ataque errado para outro alvo.", "longDescription": "Se você usar com sucesso a perícia Enganação para enganar um oponente em combate, pode redirecionar um ataque corpo a corpo errado contra você para acertar outro alvo ao alcance como reação." } } },
  { "id": "set_up", "name": "Set-up", "advantageType": "combat", "ranked": true, "maxRank": null, "description": "Transfer interaction bonus to an ally.", "longDescription": "You can transfer the benefit of a successful interaction skill use (feint, demoralize, trick) to an ally within range. Each rank lets you transfer to one ally.", "i18n": { "pt-BR": { "name": "Preparação", "description": "Transferir bônus de interação para um aliado.", "longDescription": "Você pode transferir o benefício de um uso bem-sucedido de perícia de interação (fintar, desmoralizar, enganar) para um aliado ao alcance. Cada rank permite transferir para um aliado." } } },
  { "id": "takedown", "name": "Takedown", "advantageType": "combat", "ranked": true, "maxRank": 2, "description": "Free attack on adjacent enemy after incapacitating one.", "longDescription": "If you render a minion incapacitated with a close attack, you get an immediate extra close attack against another minion within range as a free action. Rank 2: you make the extra attack against any opponent, not just minions.", "i18n": { "pt-BR": { "name": "Abater", "description": "Ataque livre contra inimigo adjacente após incapacitar um.", "longDescription": "Se você incapacitar um lacaio com um ataque corpo a corpo, recebe um ataque extra imediato contra outro lacaio ao alcance como ação livre. Rank 2: o ataque extra é contra qualquer oponente, não apenas lacaios." } } },
  { "id": "throwing_mastery", "name": "Throwing Mastery", "advantageType": "combat", "ranked": true, "maxRank": null, "description": "+1 damage with thrown weapons per rank.", "longDescription": "You have a +1 damage bonus with thrown weapons per rank of this advantage. This damage bonus is limited by power level.", "i18n": { "pt-BR": { "name": "Maestria em Arremesso", "description": "+1 de dano com armas arremessadas por rank.", "longDescription": "Você recebe +1 de bônus de dano com armas arremessadas por rank desta vantagem. Este bônus de dano é limitado pelo nível de poder." } } },
  { "id": "uncanny_dodge", "name": "Uncanny Dodge", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Not vulnerable when surprised or caught off-guard.", "longDescription": "You are not vulnerable when surprised or otherwise caught off-guard. You are still made vulnerable by effects that limit your mobility.", "i18n": { "pt-BR": { "name": "Esquiva Sobrenatural", "description": "Não fica vulnerável quando surpreendido.", "longDescription": "Você não fica vulnerável quando surpreendido ou pego desprevenido. Você ainda fica vulnerável por efeitos que limitam sua mobilidade." } } },
  { "id": "weapon_bind", "name": "Weapon Bind", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Free disarm after successful parry.", "longDescription": "If you take the defend action and successfully resist a close weapon attack, you can make a disarm attempt against the attacker as a free action.", "i18n": { "pt-BR": { "name": "Bloqueio de Arma", "description": "Desarme livre após aparar com sucesso.", "longDescription": "Se você realizar a ação de defender e resistir com sucesso a um ataque corpo a corpo com arma, pode fazer uma tentativa de desarme contra o atacante como ação livre." } } },
  { "id": "weapon_break", "name": "Weapon Break", "advantageType": "combat", "ranked": false, "maxRank": null, "description": "Free smash after successful parry.", "longDescription": "If you take the defend action and successfully resist a close weapon attack, you can make a smash attack against the attacker's weapon as a free action.", "i18n": { "pt-BR": { "name": "Quebrar Arma", "description": "Esmagar arma livre após aparar com sucesso.", "longDescription": "Se você realizar a ação de defender e resistir com sucesso a um ataque corpo a corpo com arma, pode fazer um ataque de esmagar contra a arma do atacante como ação livre." } } },
  { "id": "beginners_luck", "name": "Beginner's Luck", "advantageType": "fortune", "ranked": false, "maxRank": null, "description": "Spend hero point to gain 5 temporary ranks in a skill.", "longDescription": "By spending a hero point, you gain an effective 5 ranks in one skill of your choice you currently have at 0 ranks. These temporary ranks last for one round. This does not grant access to skills requiring training.", "i18n": { "pt-BR": { "name": "Sorte de Principiante", "description": "Gastar ponto heroico para ganhar 5 ranks temporários em uma perícia.", "longDescription": "Ao gastar um ponto heroico, você ganha 5 ranks efetivos em uma perícia à sua escolha que atualmente tenha 0 ranks. Estes ranks temporários duram uma rodada. Isso não concede acesso a perícias que requerem treinamento." } } },
  { "id": "inspire", "name": "Inspire", "advantageType": "fortune", "ranked": true, "maxRank": 5, "description": "Grant allies +1 bonus per rank.", "longDescription": "You can inspire your allies to greatness. Allies who can hear you gain a +1 circumstance bonus per rank to a type of check of your choice (attack, defense, or skill checks) for one round. You can spend a hero point to apply the bonus to all three.", "i18n": { "pt-BR": { "name": "Inspirar", "description": "Conceder +1 de bônus por rank aos aliados.", "longDescription": "Você pode inspirar seus aliados à grandeza. Aliados que podem ouvi-lo ganham +1 de bônus circunstancial por rank em um tipo de teste à sua escolha (ataque, defesa ou perícias) por uma rodada. Você pode gastar um ponto heroico para aplicar o bônus aos três." } } },
  { "id": "leadership", "name": "Leadership", "advantageType": "fortune", "ranked": false, "maxRank": null, "description": "Spend hero point to remove condition from ally.", "longDescription": "You can spend a hero point to remove one of the following conditions from an ally: dazed, fatigued, or stunned. The ally must be able to interact with you (generally be able to see and hear you).", "i18n": { "pt-BR": { "name": "Liderança", "description": "Gastar ponto heroico para remover condição de aliado.", "longDescription": "Você pode gastar um ponto heroico para remover uma das seguintes condições de um aliado: atordoado, fatigado ou aturdido. O aliado deve poder interagir com você (geralmente poder ver e ouvir você)." } } },
  { "id": "luck", "name": "Luck", "advantageType": "fortune", "ranked": true, "maxRank": null, "description": "Gain 1 extra Hero Point per rank.", "longDescription": "You gain 1 extra hero point at the start of each adventure per rank of this advantage. Your maximum rank is limited to half your power level (rounded down).", "i18n": { "pt-BR": { "name": "Sorte", "description": "Ganha 1 Ponto Heroico extra por rank.", "longDescription": "Você ganha 1 ponto heroico extra no início de cada aventura por rank desta vantagem. Seu rank máximo é limitado à metade do seu nível de poder (arredondado para baixo)." } } },
  { "id": "seize_initiative", "name": "Seize Initiative", "advantageType": "fortune", "ranked": false, "maxRank": null, "description": "Spend hero point to go first in initiative.", "longDescription": "You can spend a hero point to automatically go first in the initiative order. You may only do this at the start of combat, when you would normally make your initiative check.", "i18n": { "pt-BR": { "name": "Tomar Iniciativa", "description": "Gastar ponto heroico para agir primeiro na iniciativa.", "longDescription": "Você pode gastar um ponto heroico para automaticamente agir primeiro na ordem de iniciativa. Só pode fazer isso no início do combate, quando normalmente faria seu teste de iniciativa." } } },
  { "id": "ultimate_effort", "name": "Ultimate Effort", "advantageType": "fortune", "ranked": false, "maxRank": null, "description": "Spend hero point to treat a check as 20.", "longDescription": "You can spend a hero point on a specific type of check (chosen when you acquire this advantage) and treat the die roll as a 20 (an automatic success). Types include: skill checks, resistance checks, attack checks, etc.", "i18n": { "pt-BR": { "name": "Esforço Supremo", "description": "Gastar ponto heroico para tratar um teste como 20.", "longDescription": "Você pode gastar um ponto heroico em um tipo específico de teste (escolhido ao adquirir esta vantagem) e tratar a rolagem como 20 (sucesso automático). Os tipos incluem: testes de perícia, testes de resistência, testes de ataque, etc." } } },
  { "id": "assessment", "name": "Assessment", "advantageType": "general", "ranked": false, "maxRank": null, "description": "Evaluate opponent's combat capabilities.", "longDescription": "You can use the Insight skill as a free action to evaluate an opponent's combat capabilities. The GM tells you the relative level of the target's offensive and defensive abilities compared to yours.", "i18n": { "pt-BR": { "name": "Avaliação", "description": "Avaliar capacidades de combate do oponente.", "longDescription": "Você pode usar a perícia Intuição como ação livre para avaliar as capacidades de combate de um oponente. O Mestre informa o nível relativo das habilidades ofensivas e defensivas do alvo em comparação às suas." } } },
  { "id": "benefit", "name": "Benefit", "advantageType": "general", "ranked": true, "maxRank": null, "description": "Social benefit, wealth, rank, or narrative perk.", "longDescription": "You have some significant perquisite or fringe benefit. With the GM's permission you can have any benefit deemed reasonable. Examples include: diplomatic immunity, security clearance, wealth, status, or membership in an organization.", "i18n": { "pt-BR": { "name": "Benefício", "description": "Benefício social, riqueza, posição ou benefício narrativo.", "longDescription": "Você possui algum privilégio ou benefício significativo. Com permissão do Mestre, pode ter qualquer benefício considerado razoável. Exemplos incluem: imunidade diplomática, autorização de segurança, riqueza, status ou filiação a uma organização." } } },
  { "id": "diehard", "name": "Diehard", "advantageType": "general", "ranked": false, "maxRank": null, "description": "Automatically stabilize when dying.", "longDescription": "When you are dying you automatically stabilize on the following round without needing a Stamina check, and you do not suffer any further conditions from being dying.", "i18n": { "pt-BR": { "name": "Duro de Matar", "description": "Estabilizar automaticamente quando morrendo.", "longDescription": "Quando você está morrendo, automaticamente se estabiliza na rodada seguinte sem precisar de um teste de Vigor, e não sofre condições adicionais por estar morrendo." } } },
  { "id": "eidetic_memory", "name": "Eidetic Memory", "advantageType": "general", "ranked": false, "maxRank": null, "description": "Total recall of everything experienced.", "longDescription": "You have perfect recall. You can remember everything you have experienced in detail. You have a +5 circumstance bonus on checks to remember things, and the GM can provide you with information relevant to past experiences.", "i18n": { "pt-BR": { "name": "Memória Eidética", "description": "Recordação total de tudo que experimentou.", "longDescription": "Você tem memória perfeita. Pode lembrar de tudo que experimentou em detalhes. Tem +5 de bônus circunstancial em testes para lembrar coisas, e o Mestre pode fornecer informações relevantes às experiências passadas." } } },
  { "id": "equipment", "name": "Equipment", "advantageType": "general", "ranked": true, "maxRank": null, "description": "5 equipment points per rank.", "longDescription": "You have 5 points per rank of this advantage to spend on equipment. Equipment has a maximum cost limit based on the series power level. Equipment is less reliable than devices acquired as powers.", "i18n": { "pt-BR": { "name": "Equipamento", "description": "5 pontos de equipamento por rank.", "longDescription": "Você tem 5 pontos por rank desta vantagem para gastar em equipamento. Equipamento tem um custo máximo limitado pelo nível de poder da série. Equipamento é menos confiável do que dispositivos adquiridos como poderes." } } },
  { "id": "extraordinary_effort", "name": "Extraordinary Effort", "advantageType": "general", "ranked": false, "maxRank": null, "description": "Gain two benefits from extra effort.", "longDescription": "When you use extra effort you can gain two of the listed benefits, even stacking two of the same benefit, but you also gain two levels of fatigue.", "i18n": { "pt-BR": { "name": "Esforço Extraordinário", "description": "Ganhar dois benefícios de esforço extra.", "longDescription": "Quando você usa esforço extra, pode ganhar dois dos benefícios listados, inclusive acumulando dois do mesmo, mas também ganha dois níveis de fadiga." } } },
  { "id": "fearless", "name": "Fearless", "advantageType": "general", "ranked": false, "maxRank": null, "description": "Immune to fear effects.", "longDescription": "You are immune to fear-based effects, including Intimidation attempts to demoralize you in combat.", "i18n": { "pt-BR": { "name": "Destemido", "description": "Imune a efeitos de medo.", "longDescription": "Você é imune a efeitos baseados em medo, incluindo tentativas de Intimidação para desmoralizá-lo em combate." } } },
  { "id": "great_endurance", "name": "Great Endurance", "advantageType": "general", "ranked": false, "maxRank": null, "description": "+5 on checks against fatigue and environmental hazards.", "longDescription": "You have a +5 bonus on checks to resist or recover from fatigue and environmental conditions such as extrem heat, cold, drowning, etc.", "i18n": { "pt-BR": { "name": "Grande Resistência", "description": "+5 em testes contra fadiga e condições ambientais.", "longDescription": "Você tem +5 de bônus em testes para resistir ou se recuperar de fadiga e condições ambientais como calor extremo, frio, afogamento, etc." } } },
  { "id": "instant_up", "name": "Instant Up", "advantageType": "general", "ranked": false, "maxRank": null, "description": "Stand from prone as a free action.", "longDescription": "You can go from prone to standing as a free action without the need for an Acrobatics check.", "i18n": { "pt-BR": { "name": "Levantar Instantâneo", "description": "Levantar de caído como ação livre.", "longDescription": "Você pode se levantar de caído como ação livre sem precisar de um teste de Acrobacia." } } },
  { "id": "interpose", "name": "Interpose", "advantageType": "general", "ranked": false, "maxRank": null, "description": "Take an attack meant for an adjacent ally.", "longDescription": "Once per round, when an ally within range of your normal movement is hit by an attack, you can choose to place yourself between the attacker and your ally as a reaction, making you the target of the attack instead.", "i18n": { "pt-BR": { "name": "Interpor", "description": "Receber um ataque destinado a um aliado adjacente.", "longDescription": "Uma vez por rodada, quando um aliado ao alcance do seu movimento normal é atingido por um ataque, você pode se colocar entre o atacante e o aliado como reação, tornando-se o alvo do ataque." } } },
  { "id": "minion", "name": "Minion", "advantageType": "general", "ranked": true, "maxRank": null, "description": "Gain a minion built on 15 points per rank.", "longDescription": "You have a follower or minion. The minion is an independent character built on 15 character points per rank of this advantage. Minions follow your orders and are generally loyal to you. If your minion is lost, you can generally replace them between adventures.", "i18n": { "pt-BR": { "name": "Lacaio", "description": "Ganhar um lacaio construído com 15 pontos por rank.", "longDescription": "Você tem um seguidor ou lacaio. O lacaio é um personagem independente construído com 15 pontos por rank desta vantagem. Lacaios seguem suas ordens e são geralmente leais a você. Se seu lacaio for perdido, pode ser substituído entre aventuras." } } },
  { "id": "second_chance", "name": "Second Chance", "advantageType": "general", "ranked": true, "maxRank": null, "description": "Reroll a failed check of a specific type.", "longDescription": "Choose a particular hazard (falling, being tripped, a particular skill check, etc.). You can make a second check to avoid the hazard, taking the better result. Each rank applies to a different hazard.", "i18n": { "pt-BR": { "name": "Segunda Chance", "description": "Refazer um teste falho de um tipo específico.", "longDescription": "Escolha um perigo específico (queda, rasteira, teste de perícia específico, etc.). Você pode fazer um segundo teste para evitar o perigo, ficando com o melhor resultado. Cada rank aplica-se a um perigo diferente." } } },
  { "id": "sidekick", "name": "Sidekick", "advantageType": "general", "ranked": true, "maxRank": null, "description": "Gain a sidekick built on 5 points per rank.", "longDescription": "You have a sidekick, a non-player character built on 5 character points per rank of this advantage. Unlike minions, sidekicks are not merely followers; they are more capable and act as independent characters.", "i18n": { "pt-BR": { "name": "Parceiro", "description": "Ganhar um parceiro construído com 5 pontos por rank.", "longDescription": "Você tem um parceiro, um NPC construído com 5 pontos por rank desta vantagem. Diferente de lacaios, parceiros não são meros seguidores; são mais capazes e agem como personagens independentes." } } },
  { "id": "teamwork", "name": "Teamwork", "advantageType": "general", "ranked": false, "maxRank": null, "description": "+5 bonus to support team checks.", "longDescription": "You are skilled at working together with your allies. When you support a team check you have a +5 circumstance bonus to your check.", "i18n": { "pt-BR": { "name": "Trabalho em Equipe", "description": "+5 de bônus em testes de suporte em equipe.", "longDescription": "Você é hábil em trabalhar junto com seus aliados. Quando dá suporte em um teste de equipe, recebe +5 de bônus circunstancial." } } },
  { "id": "trance", "name": "Trance", "advantageType": "general", "ranked": false, "maxRank": null, "description": "Enter a death-like trance.", "longDescription": "Through appearance of death, deep meditation, or the like, you can place yourself into a trance state that is almost indistinguishable from death. You require no food, water, or air while in your trance but are unable to take any actions.", "i18n": { "pt-BR": { "name": "Transe", "description": "Entrar em transe semelhante à morte.", "longDescription": "Através de aparência de morte, meditação profunda, ou similar, você pode entrar em estado de transe quase indistinguível da morte. Não precisa de comida, água ou ar enquanto em transe, mas não pode realizar ações." } } },
  { "id": "agile_feint", "name": "Agile Feint", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Use Acrobatics instead of Deception to feint.", "longDescription": "You can use your Acrobatics bonus or movement speed rank in place of Deception to feint and trick in combat.", "i18n": { "pt-BR": { "name": "Finta Ágil", "description": "Usar Acrobacia ao invés de Enganação para fintar.", "longDescription": "Você pode usar seu bônus de Acrobacia ou rank de velocidade de movimento no lugar de Enganação para fintar e enganar em combate." } } },
  { "id": "animal_empathy", "name": "Animal Empathy", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Use interaction skills on animals.", "longDescription": "You can use interaction skills on animals the same as on people, making requests using your Persuasion, or using Deception or Intimidation against them. Animals' attitudes toward you begin at indifferent.", "i18n": { "pt-BR": { "name": "Empatia Animal", "description": "Usar perícias de interação com animais.", "longDescription": "Você pode usar perícias de interação com animais da mesma forma que com pessoas, fazendo pedidos usando Persuasão, ou usando Enganação ou Intimidação contra eles. A atitude dos animais começa como indiferente." } } },
  { "id": "artificer", "name": "Artificer", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Use expertise to create temporary magical items.", "longDescription": "You can use the Expertise: Magic skill to create temporary magical devices. See Inventing in Chapter 7 for details on the invention process.", "i18n": { "pt-BR": { "name": "Artífice", "description": "Usar especialidade para criar itens mágicos temporários.", "longDescription": "Você pode usar a perícia Especialidade: Magia para criar dispositivos mágicos temporários. Veja Inventar no Capítulo 7 para detalhes do processo de invenção." } } },
  { "id": "attractive", "name": "Attractive", "advantageType": "skill", "ranked": true, "maxRank": 2, "description": "Circumstance bonus for appearance-related interaction.", "longDescription": "You are particularly attractive. You gain a +2 circumstance bonus on Deception and Persuasion checks when your appearance could be a factor. With 2 ranks, you are stunningly attractive and the bonus increases to +5.", "i18n": { "pt-BR": { "name": "Atraente", "description": "Bônus circunstancial para interação baseada em aparência.", "longDescription": "Você é particularmente atraente. Ganha +2 de bônus circunstancial em testes de Enganação e Persuasão quando sua aparência pode ser fator. Com 2 ranks, você é deslumbrantemente atraente e o bônus aumenta para +5." } } },
  { "id": "connected", "name": "Connected", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Call in favors from contacts.", "longDescription": "You have connections in the world who can provide information, resources, or assistance. You can call in favors by making a Persuasion check. The GM determines the difficulty based on the scope of the favor.", "i18n": { "pt-BR": { "name": "Conexões", "description": "Pedir favores de contatos.", "longDescription": "Você tem conexões no mundo que podem fornecer informações, recursos ou assistência. Pode pedir favores fazendo um teste de Persuasão. O Mestre determina a dificuldade baseada no escopo do favor." } } },
  { "id": "contacts", "name": "Contacts", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Make Investigation checks to gather info quickly.", "longDescription": "You have extensive contacts in the area. You can make an Investigation check to gather information in minutes rather than hours.", "i18n": { "pt-BR": { "name": "Contatos", "description": "Fazer testes de Investigação para coletar informações rapidamente.", "longDescription": "Você tem contatos extensivos na área. Pode fazer um teste de Investigação para coletar informações em minutos ao invés de horas." } } },
  { "id": "daze", "name": "Daze", "advantageType": "skill", "ranked": true, "maxRank": 2, "description": "Daze a target with Deception or Intimidation.", "longDescription": "You can use Deception or Intimidation (choose one when you acquire this advantage) to daze an opponent as a standard action. The target makes a Will resistance check (DC = skill check result). Rank 2: the target is stunned instead.", "i18n": { "pt-BR": { "name": "Atordoar", "description": "Atordoar um alvo com Enganação ou Intimidação.", "longDescription": "Você pode usar Enganação ou Intimidação (escolha ao adquirir esta vantagem) para atordoar um oponente como ação padrão. O alvo faz teste de Vontade (CD = resultado do teste de perícia). Rank 2: o alvo fica aturdido." } } },
  { "id": "fascinate", "name": "Fascinate", "advantageType": "skill", "ranked": true, "maxRank": null, "description": "Entrance a target with an interaction skill.", "longDescription": "One of your interaction skills is so effective you can entrance others with it. Choose an interaction skill (Deception, Intimidation, or Persuasion). Make a skill check as a standard action; targets who fail a Will resistance check become entranced.", "i18n": { "pt-BR": { "name": "Fascinar", "description": "Fascinar um alvo com perícia de interação.", "longDescription": "Uma de suas perícias de interação é tão eficaz que pode fascinar outros. Escolha uma perícia de interação. Faça um teste de perícia como ação padrão; alvos que falham no teste de Vontade ficam fascinados." } } },
  { "id": "favored_foe", "name": "Favored Foe", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Circumstance bonus when dealing with a chosen foe type.", "longDescription": "Choose a type of creature or opponent. You gain a +2 circumstance bonus on Deception, Intimidation, Insight, and Perception checks dealing with your favored foe.", "i18n": { "pt-BR": { "name": "Inimigo Favorito", "description": "Bônus circunstancial ao lidar com um tipo de inimigo escolhido.", "longDescription": "Escolha um tipo de criatura ou oponente. Você ganha +2 de bônus circunstancial em testes de Enganação, Intimidação, Intuição e Percepção ao lidar com seu inimigo favorito." } } },
  { "id": "hide_in_plain_sight", "name": "Hide in Plain Sight", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Hide without needing cover or concealment.", "longDescription": "You can make Stealth checks to hide even while being observed and without any cover or concealment.", "i18n": { "pt-BR": { "name": "Esconder à Vista", "description": "Esconder-se sem precisar de cobertura ou ocultação.", "longDescription": "Você pode fazer testes de Furtividade para se esconder mesmo sendo observado e sem cobertura ou ocultação." } } },
  { "id": "improvised_tools", "name": "Improvised Tools", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "No penalty for lacking proper tools.", "longDescription": "You ignore the circumstance penalty for using skills without proper tools, since you can improvise tools from whatever is at hand.", "i18n": { "pt-BR": { "name": "Ferramentas Improvisadas", "description": "Sem penalidade por falta de ferramentas adequadas.", "longDescription": "Você ignora a penalidade circunstancial por usar perícias sem ferramentas adequadas, pois pode improvisar com o que estiver à mão." } } },
  { "id": "inventor", "name": "Inventor", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Use Technology to create temporary devices.", "longDescription": "You can use the Technology skill to create inventions — temporary devices. See Inventing in Chapter 7 for details.", "i18n": { "pt-BR": { "name": "Inventor", "description": "Usar Tecnologia para criar dispositivos temporários.", "longDescription": "Você pode usar a perícia Tecnologia para criar invenções — dispositivos temporários. Veja Inventar no Capítulo 7 para detalhes." } } },
  { "id": "jack_of_all_trades", "name": "Jack-of-all-trades", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Use any skill untrained.", "longDescription": "You can use any skill untrained, even skills that normally require training. You treat your ranks in any untrained skill as if they were 0 rather than being unable to use the skill.", "i18n": { "pt-BR": { "name": "Pau pra Toda Obra", "description": "Usar qualquer perícia sem treinamento.", "longDescription": "Você pode usar qualquer perícia sem treinamento, mesmo perícias que normalmente requerem treino. Você trata seus ranks em perícias não treinadas como 0 ao invés de não poder usá-las." } } },
  { "id": "languages", "name": "Languages", "advantageType": "skill", "ranked": true, "maxRank": null, "description": "Speak additional languages per rank.", "longDescription": "You can speak and understand additional languages. Each rank gives you two additional languages. With enough ranks you can speak any terrestrial language.", "i18n": { "pt-BR": { "name": "Idiomas", "description": "Falar idiomas adicionais por rank.", "longDescription": "Você pode falar e entender idiomas adicionais. Cada rank lhe concede dois idiomas adicionais. Com ranks suficientes, pode falar qualquer idioma terrestre." } } },
  { "id": "ritualist", "name": "Ritualist", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Use Expertise: Magic to perform rituals.", "longDescription": "You can use the Expertise: Magic skill to perform magic rituals to duplicate the effects of any power, given enough time, the right skills and the right circumstances. See Rituals in Chapter 7.", "i18n": { "pt-BR": { "name": "Ritualista", "description": "Usar Especialidade: Magia para realizar rituais.", "longDescription": "Você pode usar a perícia Especialidade: Magia para realizar rituais mágicos que duplicam os efeitos de qualquer poder, dado tempo, perícias e circunstâncias adequadas. Veja Rituais no Capítulo 7." } } },
  { "id": "skill_mastery", "name": "Skill Mastery", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Make routine checks under pressure with one skill.", "longDescription": "Choose a skill. You can make routine checks with that skill even when under stress or pressure (when you normally could not).", "i18n": { "pt-BR": { "name": "Maestria em Perícia", "description": "Fazer testes rotineiros sob pressão com uma perícia.", "longDescription": "Escolha uma perícia. Você pode fazer testes rotineiros com essa perícia mesmo sob estresse ou pressão (quando normalmente não poderia)." } } },
  { "id": "startle", "name": "Startle", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Use Intimidation to feint in combat.", "longDescription": "You can use your Intimidation bonus in place of Deception to feint in combat. See the feint action in Chapter 8.", "i18n": { "pt-BR": { "name": "Assustar", "description": "Usar Intimidação para fintar em combate.", "longDescription": "Você pode usar seu bônus de Intimidação no lugar de Enganação para fintar em combate. Veja a ação de finta no Capítulo 8." } } },
  { "id": "taunt", "name": "Taunt", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Use Deception to demoralize.", "longDescription": "You can use your Deception bonus in place of Intimidation to demoralize an opponent in combat. See the demoralize action in Chapter 8.", "i18n": { "pt-BR": { "name": "Provocar", "description": "Usar Enganação para desmoralizar.", "longDescription": "Você pode usar seu bônus de Enganação no lugar de Intimidação para desmoralizar um oponente em combate. Veja a ação de desmoralizar no Capítulo 8." } } },
  { "id": "tracking", "name": "Tracking", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Use Perception to follow tracks.", "longDescription": "You can use the Perception skill to visually follow tracks and trails, using the guidelines for the tracking sense (see Senses in Chapter 6).", "i18n": { "pt-BR": { "name": "Rastreamento", "description": "Usar Percepção para seguir rastros.", "longDescription": "Você pode usar a perícia Percepção para seguir rastros visualmente, usando as diretrizes para o sentido de rastreamento (veja Sentidos no Capítulo 6)." } } },
  { "id": "well_informed", "name": "Well-informed", "advantageType": "skill", "ranked": false, "maxRank": null, "description": "Make immediate Investigation or Persuasion check for info.", "longDescription": "You are well-connected and always seem to be 'in the know.' When you encounter a new situation or individual, you can make an immediate Investigation or Persuasion check to see if you know something useful.", "i18n": { "pt-BR": { "name": "Bem Informado", "description": "Fazer teste imediato de Investigação ou Persuasão para informações.", "longDescription": "Você é bem conectado e parece sempre estar 'por dentro.' Ao encontrar uma nova situação ou indivíduo, pode fazer um teste imediato de Investigação ou Persuasão para ver se sabe algo útil." } } }
]
